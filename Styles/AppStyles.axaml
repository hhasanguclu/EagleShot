<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern toolbar button style -->
    <Style Selector="Button.tool-btn">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#FF232328"/>
        <Setter Property="Foreground" Value="#FFE0E0E0"/>
        <Setter Property="BorderBrush" Value="#FF3A3A42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tool-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF3A3A45"/>
        <Setter Property="BorderBrush" Value="#FF5A5A6A"/>
    </Style>
    <Style Selector="Button.tool-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF1A1A20"/>
    </Style>
    <Style Selector="Button.tool-btn.selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF1A1A20"/>
        <Setter Property="BorderBrush" Value="#FF6495ED"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Action button (green accent) -->
    <Style Selector="Button.action-btn">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#FF232328"/>
        <Setter Property="Foreground" Value="#FF50C878"/>
        <Setter Property="BorderBrush" Value="#FF3A3A42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF2A3A2A"/>
        <Setter Property="BorderBrush" Value="#FF50C878"/>
    </Style>

    <!-- Close button (red accent) -->
    <Style Selector="Button.close-btn">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#FF232328"/>
        <Setter Property="Foreground" Value="#FFDC3545"/>
        <Setter Property="BorderBrush" Value="#FF3A3A42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF3A2020"/>
        <Setter Property="BorderBrush" Value="#FFDC3545"/>
    </Style>

    <!-- Pen width button -->
    <Style Selector="Button.pen-btn">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#FF232328"/>
        <Setter Property="Foreground" Value="#FFFFA500"/>
        <Setter Property="BorderBrush" Value="#FF3A3A42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.pen-btn.selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF1A1A20"/>
        <Setter Property="BorderBrush" Value="#FFFFA500"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Button.pen-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF3A3020"/>
        <Setter Property="BorderBrush" Value="#FFFFA500"/>
    </Style>

    <!-- Separator -->
    <Style Selector="Border.separator">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="#FF3A3A42"/>
        <Setter Property="Margin" Value="6,0"/>
    </Style>

    <!-- Color swatch button -->
    <Style Selector="Button.color-swatch">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.color-swatch:pointerover /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="White"/>
    </Style>
    <Style Selector="Button.color-swatch.selected /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="White"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <!-- Text size button -->
    <Style Selector="Button.text-size-btn">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#E0202028"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#FF4A4A55"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.text-size-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF3A3A45"/>
        <Setter Property="BorderBrush" Value="#FF6495ED"/>
    </Style>

</Styles>
