<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:EagleShot.Views"
        x:Class="EagleShot.Views.OverlayWindow"
        Title="EagleShot Overlay"
        SystemDecorations="None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        Name="OverlayRoot">
    <Panel Name="RootPanel">
        <!-- Custom canvas that handles all drawing + pointer events -->
        <views:OverlayCanvas Name="Canvas" />

        <!-- Floating toolbar (hidden until selection is made) -->
        <Border Name="ToolbarBorder"
                IsVisible="False"
                Background="#E6161620"
                CornerRadius="12"
                Padding="6"
                BoxShadow="0 4 24 0 #80000000"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Spacing="2" Name="ToolbarPanel">
                <!-- Drawing tools -->
                <Button Classes="tool-btn" Tag="Pen" Click="OnToolClick" ToolTip.Tip="Pen">
                    <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" Width="18" Height="18" Foreground="White"/>
                </Button>
                <Button Classes="tool-btn" Tag="Line" Click="OnToolClick" ToolTip.Tip="Line">
                    <TextBlock Text="/" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="tool-btn" Tag="Arrow" Click="OnToolClick" ToolTip.Tip="Arrow">
                    <PathIcon Data="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z" Width="18" Height="18" Foreground="White">
                        <PathIcon.RenderTransform>
                            <RotateTransform Angle="45"/>
                        </PathIcon.RenderTransform>
                    </PathIcon>
                </Button>
                <Button Classes="tool-btn" Tag="Rectangle" Click="OnToolClick" ToolTip.Tip="Rectangle">
                    <Border Width="16" Height="12" BorderBrush="White" BorderThickness="2" CornerRadius="2"/>
                </Button>
                <Button Classes="tool-btn" Tag="Text" Click="OnToolClick" ToolTip.Tip="Text">
                    <TextBlock Text="T" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="tool-btn" Tag="Highlight" Click="OnToolClick" ToolTip.Tip="Highlight">
                    <Border Width="16" Height="8" Background="#80FFFF00" CornerRadius="2"/>
                </Button>
                <Button Classes="tool-btn" Tag="Number" Click="OnToolClick" ToolTip.Tip="Number">
                    <TextBlock Text="#" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="tool-btn" Tag="Mosaic" Click="OnToolClick" ToolTip.Tip="Mosaic">
                    <Grid Width="16" Height="16">
                        <Border Width="7" Height="7" Background="#AAA" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Border Width="7" Height="7" Background="#666" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Border Width="7" Height="7" Background="#666" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Border Width="7" Height="7" Background="#AAA" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </Button>

                <Border Classes="separator"/>

                <!-- Color picker -->
                <Button Classes="tool-btn" Name="ColorButton" ToolTip.Tip="Color">
                    <Button.Flyout>
                        <Flyout Placement="Top" ShowMode="TransientWithDismissOnPointerMoveAway">
                            <Border Background="#F0181820" CornerRadius="10" Padding="10" BoxShadow="0 2 12 0 #60000000">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Color" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                                    <ItemsControl Name="ColorGrid">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" MaxWidth="200"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <Border Name="ColorPreview" Width="18" Height="18" CornerRadius="4" Background="Red" BorderBrush="White" BorderThickness="1"/>
                </Button>

                <!-- Pen widths -->
                <Button Classes="pen-btn" Tag="1" Click="OnPenWidthClick" ToolTip.Tip="1px">
                    <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="pen-btn" Tag="3" Click="OnPenWidthClick" ToolTip.Tip="3px">
                    <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="pen-btn" Tag="5" Click="OnPenWidthClick" ToolTip.Tip="5px">
                    <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Classes="pen-btn" Tag="8" Click="OnPenWidthClick" ToolTip.Tip="8px">
                    <TextBlock Text="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <Border Classes="separator"/>

                <!-- Actions -->
                <Button Classes="action-btn" Click="OnUndoClick" ToolTip.Tip="Undo">
                    <PathIcon Data="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z" Width="16" Height="16" Foreground="#50C878"/>
                </Button>
                <Button Classes="action-btn" Click="OnCopyClick" ToolTip.Tip="Copy">
                    <PathIcon Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" Width="16" Height="16" Foreground="#50C878"/>
                </Button>
                <Button Classes="action-btn" Click="OnSaveClick" ToolTip.Tip="Save">
                    <PathIcon Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" Width="16" Height="16" Foreground="#50C878"/>
                </Button>

                <Border Classes="separator"/>

                <Button Classes="close-btn" Click="OnCloseClick" ToolTip.Tip="Close">
                    <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="16" Height="16" Foreground="#DC3545"/>
                </Button>
            </StackPanel>
        </Border>
    </Panel>
</Window>
